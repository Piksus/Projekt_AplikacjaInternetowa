@model LoginViewModel
@{
    ViewData["Title"] = "Logowanie";
}

<section>
    <h2>Logowanie organizatora</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p style="color:#c0392b;margin-bottom:12px">@Model.ErrorMessage</p>
    }

    <form method="post" asp-controller="Account" asp-action="Login">
        <div class="form-group">
            <label asp-for="Username">Login</label>
            <input asp-for="Username" class="form-input" />
        </div>
        <div class="form-group">
            <label asp-for="Password">Hasło</label>
            <input asp-for="Password" type="password" class="form-input" />
        </div>
        <button type="submit" class="btn btn-primary">Zaloguj</button>
    </form>
</section>
